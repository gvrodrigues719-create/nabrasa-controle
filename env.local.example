# Copie este arquivo para .env.local e preencha com as credenciais do seu projeto Supabase.
# O arquivo .env.local é ignorado pelo git (não commitar credenciais reais).

NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sua-chave-anon-key>

# Necessário apenas para os scripts utilitários (importCsv.mjs, check_migration.mjs etc.)
# Nunca expor esta chave no frontend.
SUPABASE_SERVICE_ROLE_KEY=<sua-service-role-key>
